<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historial por alumno | Notas Escolares</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/tokens.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/table.css">
  <link rel="stylesheet" href="/css/forms.css">

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      overflow-x: hidden;
      overflow-y: auto;
      -webkit-text-size-adjust: 100%;
    }

    body {
      background: var(--color-bg);
      color: var(--color-text);
    }

    .page-shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--space-8);
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--space-4);
      margin-bottom: var(--space-6);
      padding: var(--space-6);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-sm);
    }

    .page-title h1 {
      margin: 0 0 var(--space-2);
      font-size: var(--text-2xl);
      font-family: var(--font-display, "Instrument Serif", serif);
      font-weight: 500;
    }

    .page-title p {
      margin: 0;
      color: var(--color-text-muted);
      max-width: 68ch;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      text-decoration: none;
      color: var(--color-text);
      background: var(--color-surface-2);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 10px 14px;
      white-space: nowrap;
      min-height: 44px;
    }

    .back-link:hover {
      background: var(--color-surface-offset);
    }

    .toolbar {
      display: grid;
      grid-template-columns: 1.5fr auto;
      gap: var(--space-4);
      margin-bottom: var(--space-5);
      padding: var(--space-5);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-sm);
      align-items: end;
    }

    .field label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: var(--color-text);
    }

    .field select {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface-2);
      color: var(--color-text);
      min-height: 44px;
    }

    .toolbar button {
      padding: 12px 16px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-primary);
      color: var(--color-text-inverse);
      font-weight: 600;
      cursor: pointer;
      min-width: 160px;
      min-height: 44px;
    }

    .toolbar button:hover {
      background: var(--color-primary-hover);
    }

    .student-summary {
      display: grid;
      grid-template-columns: repeat(5, minmax(180px, 1fr));
      gap: var(--space-4);
      margin-bottom: var(--space-5);
    }

    .summary-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-5);
      box-shadow: var(--shadow-sm);
      min-width: 0;
    }

    .summary-card small {
  display: block;
  color: var(--color-text-muted);
  margin-bottom: 6px;
  font-size: var(--text-xs);
  line-height: 1.2;
}

.summary-card strong {
  display: block;
  font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  font-weight: 700;
  line-height: 1.2;
  color: var(--color-text);
  font-variant-numeric: tabular-nums;
  word-break: break-word;
}



    .panel {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-5);
      border-bottom: 1px solid var(--color-border);
      flex-wrap: wrap;
    }

    .panel-head h2 {
      margin: 0;
      font-size: var(--text-lg);
    }

    .panel-head p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--text-sm);
    }

    .table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 860px;
    }

    thead th {
      text-align: left;
      background: var(--color-surface-2);
      color: var(--color-text);
      font-size: var(--text-sm);
      padding: 14px 12px;
      border-bottom: 1px solid var(--color-border);
      white-space: nowrap;
    }

    tbody td {
      padding: 14px 12px;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-text);
      vertical-align: middle;
    }

    tbody tr:hover {
      background: var(--color-surface-2);
    }

    .nota {
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    .nota.alta { color: var(--color-success); }
    .nota.media { color: var(--color-blue); }
    .nota.baja { color: var(--color-warning); }
    .nota.critica { color: var(--color-error); }

    .empty-state,
    .loading-state,
    .error-state {
      padding: var(--space-8);
      text-align: center;
      color: var(--color-text-muted);
    }

    @media (max-width: 900px) {
      .student-summary {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .page-shell {
        padding: var(--space-4);
      }

      .page-header {
        flex-direction: column;
      }

      .back-link {
        width: 100%;
        justify-content: center;
      }

      .toolbar {
        grid-template-columns: 1fr;
      }

      .toolbar button {
        width: 100%;
      }

      .student-summary {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 700px) {
      .panel {
        overflow: visible;
      }

      .table-wrap {
        overflow: visible;
      }

      table,
      thead,
      tbody,
      tr,
      td {
        display: block;
        width: 100%;
        min-width: 0;
      }

      thead {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      tbody tr {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        margin-bottom: var(--space-4);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
      }

      tbody td {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: .7rem .9rem;
        border-bottom: 1px solid var(--color-divider);
        text-align: right;
      }

      tbody td:last-child {
        border-bottom: 0;
      }

      tbody td::before {
        content: attr(data-label);
        font-weight: 600;
        color: var(--color-text-muted);
        text-align: left;
        flex: 0 0 40%;
        max-width: 40%;
      }
    }
  </style>
</head>
<body>
  <main class="page-shell">
    <section class="page-header">
      <div class="page-title">
        <h1>Historial por alumno</h1>
        <p>
          Revisa todas las evaluaciones registradas de un alumno, ordenadas por fecha, con asignatura, profesor, tipo y observaciones.
        </p>
      </div>
      <a class="back-link" href="/reportes.html">
        <i data-lucide="arrow-left" size="16"></i>
        Volver a informes
      </a>
    </section>

    <section class="toolbar">
      <div class="field">
        <label for="alumno-select">Selecciona un alumno</label>
        <select id="alumno-select">
          <option value="">Cargando alumnos...</option>
        </select>
      </div>
      <button id="btn-cargar" type="button">Ver historial</button>
    </section>

    <section class="student-summary">
      <article class="summary-card">
        <small>Alumno</small>
        <strong id="stat-alumno">-</strong>
      </article>
      <article class="summary-card">
        <small>RUT</small>
        <strong id="stat-rut">-</strong>
      </article>
      <article class="summary-card">
        <small>Curso</small>
        <strong id="stat-curso">-</strong>
      </article>
      <article class="summary-card">
        <small>Total notas</small>
        <strong id="stat-total">0</strong>
      </article>
      <article class="summary-card">
        <small>Promedio</small>
        <strong id="stat-promedio">0.00</strong>
      </article>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <h2>Detalle de evaluaciones</h2>
          <p>Listado cronológico descendente de notas registradas para el alumno seleccionado.</p>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Asignatura</th>
              <th>Tipo</th>
              <th>Nota</th>
              <th>Profesor</th>
              <th>Observación</th>
            </tr>
          </thead>
          <tbody id="tabla-historial">
            <tr>
              <td colspan="6" class="empty-state">Selecciona un alumno para ver su historial.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    lucide.createIcons();

    const alumnoSelect = document.getElementById("alumno-select");
    const btnCargar = document.getElementById("btn-cargar");
    const tbody = document.getElementById("tabla-historial");

    const statAlumno = document.getElementById("stat-alumno");
    const statRut = document.getElementById("stat-rut");
    const statCurso = document.getElementById("stat-curso");
    const statTotal = document.getElementById("stat-total");
    const statPromedio = document.getElementById("stat-promedio");

    function claseNota(valor) {
      const n = Number(valor);
      if (n >= 6.0) return "alta";
      if (n >= 5.0) return "media";
      if (n >= 4.0) return "baja";
      return "critica";
    }

    function formatNota(valor) {
      const n = Number(valor);
      return Number.isFinite(n) ? n.toFixed(2) : "0.00";
    }

    function formatFecha(valor) {
      if (!valor) return "-";
      const fecha = new Date(valor);
      if (Number.isNaN(fecha.getTime())) return valor;
      return fecha.toLocaleDateString("es-CL");
    }

    function resetVista() {
      tbody.innerHTML = `<tr><td colspan="6" class="empty-state">Selecciona un alumno para ver su historial.</td></tr>`;
      statAlumno.textContent = "-";
      statRut.textContent = "-";
      statCurso.textContent = "-";
      statTotal.textContent = "0";
      statPromedio.textContent = "0.00";
    }

    async function cargarAlumnos() {
      try {
        const res = await fetch("/api/alumnos");
        const data = await res.json();
        const alumnos = Array.isArray(data) ? data : (data.data || []);

        if (!alumnos.length) {
          alumnoSelect.innerHTML = `<option value="">No hay alumnos disponibles</option>`;
          return;
        }

        alumnoSelect.innerHTML = `
          <option value="">Selecciona un alumno</option>
          ${alumnos
            .sort((a, b) =>
              String((a.nombres || "") + " " + (a.apellidos || "")).localeCompare(
                String((b.nombres || "") + " " + (b.apellidos || "")),
                "es"
              )
            )
            .map(al => {
              const alumnoId = al.id ?? al._id ?? al.alumno_id ?? "";
              const nombre = `${(al.nombres || "").trim()} ${(al.apellidos || "").trim()}`.trim();
              return `
                <option value="${String(alumnoId)}">
                  ${nombre}${al.rut ? " — " + al.rut : ""}
                </option>
              `;
            })
            .join("")}
        `;
      } catch (error) {
        alumnoSelect.innerHTML = `<option value="">Error al cargar alumnos</option>`;
      }
    }

    async function cargarHistorial() {
      const alumnoId = alumnoSelect.value;

      if (!alumnoId) {
        resetVista();
        return;
      }

      tbody.innerHTML = `<tr><td colspan="6" class="loading-state">Cargando historial...</td></tr>`;

      try {
        const res = await fetch(`/api/reportes/historial/${encodeURIComponent(alumnoId)}`);
        const json = await res.json();

        if (!res.ok || !json.ok) {
          throw new Error(json.error || "No se pudo cargar el historial");
        }

        const rows = Array.isArray(json.data) ? json.data : [];

        statAlumno.textContent = json.alumno || "-";
        statRut.textContent = json.rut || "-";
        statCurso.textContent = json.curso || "-";
        statTotal.textContent = String(rows.length);

        const notas = rows.map(r => Number(r.valor)).filter(Number.isFinite);
        const promedio = notas.length
          ? (notas.reduce((acc, v) => acc + v, 0) / notas.length).toFixed(2)
          : "0.00";
        statPromedio.textContent = promedio;

        if (!rows.length) {
          tbody.innerHTML = `<tr><td colspan="6" class="empty-state">El alumno no tiene evaluaciones registradas.</td></tr>`;
          return;
        }

        tbody.innerHTML = rows.map(item => `
          <tr>
            <td data-label="Fecha">${formatFecha(item.fecha)}</td>
            <td data-label="Asignatura">${item.asignatura || ""}</td>
            <td data-label="Tipo">${item.tipo || "-"}</td>
            <td data-label="Nota"><span class="nota ${claseNota(item.valor)}">${formatNota(item.valor)}</span></td>
            <td data-label="Profesor">${item.profesor || "-"}</td>
            <td data-label="Observación">${item.obs || "-"}</td>
          </tr>
        `).join("");
      } catch (error) {
        tbody.innerHTML = `<tr><td colspan="6" class="error-state">${error.message}</td></tr>`;
        statTotal.textContent = "0";
        statPromedio.textContent = "0.00";
      }
    }

    btnCargar.addEventListener("click", cargarHistorial);

    alumnoSelect.addEventListener("change", () => {
      if (alumnoSelect.value) {
        cargarHistorial();
      } else {
        resetVista();
      }
    });

    cargarAlumnos();
  </script>
</body>
</html>