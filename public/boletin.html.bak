<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Boletín de Notas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&display=swap" rel="stylesheet">
  <style>
    /* ── Variables ── */
    :root {
      --primary: #01696f;
      --text: #28251d;
      --muted: #7a7974;
      --border: #d4d1ca;
      --bg: #f7f6f2;
      --surface: #ffffff;
      --success: #437a22;
      --error: #a12c7b;
      --radius: 0.5rem;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
    }

    /* ── Selector de alumno (no se imprime) ── */
    #selector {
      max-width: 480px;
      margin: 3rem auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      box-shadow: 0 4px 12px rgba(0,0,0,.07);
    }
    #selector h2 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: var(--text);
    }
    #selector label { display:block; font-size:.8rem; color:var(--muted); margin-bottom:.35rem; }
    #selector select, #selector input {
      width: 100%; padding: .5rem .75rem;
      border: 1px solid var(--border); border-radius: var(--radius);
      font: inherit; color: var(--text); background: var(--bg);
      margin-bottom: 1rem;
    }
    #selector select:focus, #selector input:focus {
      outline: 2px solid var(--primary); outline-offset: 2px;
    }
    .btn-group { display:flex; gap:.75rem; }
    .btn {
      flex: 1; padding: .55rem 1rem; border-radius: var(--radius);
      font: inherit; font-size: .85rem; font-weight: 500;
      cursor: pointer; border: none; transition: background .15s;
    }
    .btn-primary { background: var(--primary); color: #fff; }
    .btn-primary:hover { background: #0c4e54; }
    .btn-ghost  { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--bg); }

    /* ── Boletín ── */
    #boletin {
      display: none;
      max-width: 720px;
      margin: 2rem auto 3rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2.5rem;
      box-shadow: 0 4px 12px rgba(0,0,0,.07);
    }

    .boletin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 1.25rem;
      border-bottom: 2px solid var(--primary);
      margin-bottom: 1.5rem;
    }
    .boletin-logo {
      display: flex; align-items: center; gap: .5rem;
      font-weight: 700; font-size: 1rem; color: var(--primary);
    }
    .boletin-logo svg { width:28px; height:28px; }
    .boletin-titulo { font-size: .7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-top: .15rem; }

    .alumno-info { margin-bottom: 1.5rem; }
    .alumno-nombre { font-size: 1.3rem; font-weight: 700; margin-bottom: .3rem; }
    .alumno-meta { display: flex; gap: 2rem; flex-wrap: wrap; }
    .alumno-meta span { font-size: .8rem; color: var(--muted); }
    .alumno-meta strong { color: var(--text); }

    /* Tabla de notas */
    .tabla-notas {
      width: 100%; border-collapse: collapse;
      margin-bottom: 1.5rem; font-size: .82rem;
    }
    .tabla-notas thead th {
      background: var(--bg);
      padding: .5rem .75rem;
      text-align: left;
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    .tabla-notas tbody td {
      padding: .6rem .75rem;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .tabla-notas tbody tr:last-child td { border-bottom: none; }
    .tabla-notas .asig-nombre { font-weight: 600; }
    .tabla-notas .prof-nombre { font-size: .75rem; color: var(--muted); }

    /* Chips de notas individuales */
    .notas-lista { display: flex; flex-wrap: wrap; gap: .3rem; }
    .nota-chip {
      display: inline-flex; flex-direction: column; align-items: center;
      padding: .15rem .45rem;
      border-radius: .3rem;
      font-size: .78rem; font-weight: 600; min-width: 2rem;
    }
    .nota-chip .tipo { font-size: .6rem; font-weight: 400; opacity: .75; }
    .chip-verde   { background: #d4dfcc; color: #2e5c10; }
    .chip-azul    { background: #c6d8e4; color: #0b5177; }
    .chip-amarillo{ background: #e9e0c6; color: #8a5b00; }
    .chip-rojo    { background: #e0ced7; color: #7d1e5e; }

    /* Celda promedio */
    .prom-badge {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .2rem .6rem; border-radius: 9999px;
      font-weight: 700; font-size: .85rem;
    }

    /* Fila promedio general */
    .fila-promedio-general td {
      background: var(--bg);
      font-weight: 700;
      border-top: 2px solid var(--border);
      font-size: .9rem;
    }

    /* Pie de boletín */
    .boletin-footer {
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: .75rem;
      color: var(--muted);
    }
    .estado-badge {
      padding: .3rem .9rem; border-radius: 9999px;
      font-weight: 700; font-size: .85rem;
    }
    .aprobado  { background: #d4dfcc; color: #2e5c10; }
    .reprobado { background: #e0ced7; color: #7d1e5e; }
    .sin-notas { background: var(--bg); color: var(--muted); border: 1px solid var(--border); }

    /* Botones de acción (no se imprimen) */
    #acciones {
      max-width: 720px; margin: 0 auto 1.5rem;
      display: none; gap: .75rem;
    }

    /* ── PRINT ── */
    @media print {
      body { background: #fff; font-size: 12px; }
      #selector, #acciones { display: none !important; }
      #boletin {
        display: block !important;
        box-shadow: none; border: none;
        margin: 0; padding: 1.5cm;
        max-width: 100%;
      }
      .boletin-header { border-bottom-color: #000; }
      .nota-chip { border: 1px solid #ccc; }
      .prom-badge { border: 1px solid #ccc; }
    }
  </style>
</head>
<body>

<!-- ── Selector de alumno ── -->
<div id="selector">
  <h2>📋 Boletín de Notas</h2>
  <label>Selecciona el alumno</label>
  <select id="sel-alumno">
    <option value="">Cargando alumnos…</option>
  </select>
  <label>Período / observación (opcional)</label>
  <input type="text" id="sel-periodo" placeholder="Ej: Primer semestre 2025">
  <div class="btn-group">
    <button class="btn btn-primary" onclick="generarBoletin()">Ver boletín</button>
    <button class="btn btn-ghost" onclick="window.location='/'">← Volver</button>
  </div>
</div>

<!-- ── Botones de acción ── -->
<div id="acciones">
  <button class="btn btn-primary" onclick="window.print()">🖨️ Imprimir / Guardar PDF</button>
  <button class="btn btn-ghost" onclick="resetBoletin()">← Cambiar alumno</button>
</div>

<!-- ── Boletín ── -->
<div id="boletin">
  <!-- se rellena con JS -->
</div>

<script>
  // Cargar alumnos al iniciar
  (async () => {
    const alumnos = await fetch('/api/alumnos').then(r => r.json());
    const sel = document.getElementById('sel-alumno');
    sel.innerHTML = '<option value="">-- Selecciona un alumno --</option>' +
      alumnos.map(a => `<option value="${a.id}">${a.apellidos}, ${a.nombres} (${a.curso_nombre || ''})</option>`).join('');
  })();

  function chipColor(v) {
    if (v >= 6.5) return 'chip-verde';
    if (v >= 5.0) return 'chip-azul';
    if (v >= 4.0) return 'chip-amarillo';
    return 'chip-rojo';
  }
  function promColor(v) {
    if (v >= 6.5) return 'chip-verde';
    if (v >= 5.0) return 'chip-azul';
    if (v >= 4.0) return 'chip-amarillo';
    return 'chip-rojo';
  }

  async function generarBoletin() {
    const id = document.getElementById('sel-alumno').value;
    if (!id) return alert('Selecciona un alumno primero');

    const data = await fetch(`/api/boletin/${id}`).then(r => r.json());
    const periodo = document.getElementById('sel-periodo').value || new Date().getFullYear();
    const { alumno, asignaturas, promedioGeneral } = data;

    const filas = asignaturas.map(a => {
      const chips = a.notas.map(n =>
        `<span class="nota-chip ${chipColor(n.valor)}">${n.valor.toFixed(1)}<span class="tipo">${n.tipo}</span></span>`
      ).join('');
      const prom = a.promedio !== null
        ? `<span class="prom-badge ${promColor(a.promedio)}">${a.promedio.toFixed(1)}</span>`
        : '<span style="color:var(--muted)">—</span>';
      return `
        <tr>
          <td>
            <div class="asig-nombre">${a.nombre}</div>
            <div class="prof-nombre">${a.profesor}</div>
          </td>
          <td><div class="notas-lista">${chips || '<span style="color:var(--muted);font-size:.8rem">Sin notas</span>'}</div></td>
          <td style="text-align:center">${prom}</td>
        </tr>`;
    }).join('');

    const pg = promedioGeneral !== null
      ? `<span class="prom-badge ${promColor(promedioGeneral)}" style="font-size:1rem">${promedioGeneral.toFixed(1)}</span>`
      : '—';

    const estado = promedioGeneral === null ? 'sin-notas'
      : promedioGeneral >= 4.0 ? 'aprobado' : 'reprobado';
    const estadoTxt = promedioGeneral === null ? 'Sin evaluaciones'
      : promedioGeneral >= 4.0 ? '✓ Aprobado' : '✗ Reprobado';

    document.getElementById('boletin').innerHTML = `
      <div class="boletin-header">
        <div>
          <div class="boletin-logo">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="32" height="32" rx="8" fill="currentColor"/>
              <path d="M8 10h16M8 16h10M8 22h13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            Notas Escolares
          </div>
          <div class="boletin-titulo">Boletín oficial de calificaciones</div>
        </div>
        <div style="text-align:right;font-size:.8rem;color:var(--muted)">
          <div>${periodo}</div>
          <div>Emitido: ${new Date().toLocaleDateString('es-CL')}</div>
        </div>
      </div>

      <div class="alumno-info">
        <div class="alumno-nombre">${alumno.apellidos}, ${alumno.nombres}</div>
        <div class="alumno-meta">
          <span>Curso: <strong>${alumno.curso_nombre || '—'}</strong></span>
          <span>Año: <strong>${alumno.anio || '—'}</strong></span>
          <span>RUT: <strong>${alumno.rut || '—'}</strong></span>
          <span>Estado: <strong>${alumno.estado}</strong></span>
        </div>
      </div>

      <table class="tabla-notas">
        <thead>
          <tr>
            <th style="width:35%">Asignatura / Profesor</th>
            <th>Evaluaciones</th>
            <th style="width:10%;text-align:center">Promedio</th>
          </tr>
        </thead>
        <tbody>
          ${filas || '<tr><td colspan="3" style="text-align:center;color:var(--muted);padding:2rem">Sin notas registradas</td></tr>'}
          <tr class="fila-promedio-general">
            <td>Promedio General</td>
            <td></td>
            <td style="text-align:center">${pg}</td>
          </tr>
        </tbody>
      </table>

      <div class="boletin-footer">
        <span>Este documento es de carácter informativo.</span>
        <span class="estado-badge ${estado}">${estadoTxt}</span>
      </div>
    `;

    document.getElementById('selector').style.display = 'none';
    document.getElementById('boletin').style.display = 'block';
    document.getElementById('acciones').style.display = 'flex';
  }

  function resetBoletin() {
    document.getElementById('selector').style.display = 'block';
    document.getElementById('boletin').style.display = 'none';
    document.getElementById('acciones').style.display = 'none';
  }
</script>
</body>
</html>
