generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profesor {
  id           Int       @id @default(autoincrement())
  nombres      String
  apellidos    String
  rut          String?
  email        String?
  especialidad String?
  estado       String    @default("Activo")
  creado_en    DateTime  @default(now())
  cursos       Curso[]
  notas        Nota[]
}

model Curso {
  id        Int       @id @default(autoincrement())
  nombre    String
  nivel     String    @default("Básico")
  anio      Int       @default(2025)
  jefe_id   Int?
  jefe      Profesor? @relation(fields: [jefe_id], references: [id])
  creado_en DateTime  @default(now())
  alumnos   Alumno[]
}

model Alumno {
  id        Int      @id @default(autoincrement())
  nombres   String
  apellidos String
  rut       String?
  nac       String?
  curso_id  Int?
  curso     Curso?   @relation(fields: [curso_id], references: [id])
  email     String?
  tel       String?
  estado    String   @default("Activo")
  creado_en DateTime @default(now())
  notas     Nota[]
}

model Asignatura {
  id        Int      @id @default(autoincrement())
  nombre    String
  codigo    String?
  horas     Int      @default(4)
  desc      String?
  creado_en DateTime @default(now())
  notas     Nota[]
}

model Nota {
  id         Int        @id @default(autoincrement())
  alumno_id  Int
  alumno     Alumno     @relation(fields: [alumno_id], references: [id], onDelete: Cascade)
  asig_id    Int
  asignatura Asignatura @relation(fields: [asig_id], references: [id], onDelete: Cascade)
  prof_id    Int?
  profesor   Profesor?  @relation(fields: [prof_id], references: [id])
  valor      Float
  tipo       String     @default("Prueba")
  fecha      DateTime   @default(now())
  obs        String?
  creado_en  DateTime   @default(now())
}